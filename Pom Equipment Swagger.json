      "type": "object",
      "required": [
        "value"
      ],
      "properties": {
        "@odata.context": {
          "type": "string"
        },
        "@odata.metadataEtag": {
          "type": "string"
        },
        "value": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EquipmentRecord"
          }
        }
      }
    },
    "EquipmentListResponse": {
      "type": "object",
