{
  "swagger": "2.0",
  "info": {
    "title": "Pom Equipment API",
    "version": "1.0.0",
    "description": "Swagger 2.0 definition for the Pom Equipment service."
  },
  "host": "pomerleaudev.test.apimanagement.ca10.hana.ondemand.com",
  "schemes": ["https"],
  "basePath": "/EquipmentRead",
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "paths": {
    "/Equipment": {
      "get": {
        "summary": "Retrieve equipment records",
        "description": "Returns a list of equipment records in the OData-style envelope.",
        "parameters": [
          {
            "name": "$top",
            "in": "query",
            "type": "integer",
            "format": "int32",
            "description": "Maximum number of records to return",
            "default": 1000
          },
          {
            "name": "$expand",
            "in": "query",
            "type": "string",
            "description": "OData expand clause",
            "default": "_CompanyCode($select=CompanyCodeName),_EquipmentText($select=EquipmentName;$filter=Language eq 'EN'),_MasterFixedAsset($select=MasterFixedAssetDescription),_Supplier($select=SupplierFullName),_TechnicalObjectTypeText($select=TechnicalObjectTypeDesc;$filter=Language eq 'EN'),_WBSElement($select=WBSElement,WBSDescription)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "schema": {
              "$ref": "#/definitions/EquipmentListResponse"
            }
          }
        }
      },
      "post": {
        "summary": "Create equipment records",
        "description": "Creates new equipment records and returns the created records.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/EquipmentListRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Resource created",
            "schema": {
              "$ref": "#/definitions/EquipmentListResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "EquipmentListRequest": {
      "type": "object",
      "properties": {
        "@odata.context": { "type": "string" },
        "@odata.metadataEtag": { "type": "string" },
        "value": {
          "type": "array",
          "items": { "$ref": "#/definitions/EquipmentRecord" }
        }
      },
      "required": ["value"]
    },
    "EquipmentListResponse": {
      "type": "object",
      "properties": {
        "@odata.context": { "type": "string" },
        "@odata.metadataEtag": { "type": "string" },
        "value": {
          "type": "array",
          "items": { "$ref": "#/definitions/EquipmentRecord" }
        }
      },
      "required": ["@odata.context", "@odata.metadataEtag", "value"]
    },
    "EquipmentRecord": {
      "type": "object",
      "properties": {
        "Equipment": { "type": "string" },
        "MaintObjectInternalID": { "type": "string" },
        "TechnicalObjectType": { "type": "string" },
        "AssetManufacturerName": { "type": "string" },
        "ManufacturerPartTypeName": { "type": "string" },
        "ManufacturerPartNmbr": { "type": "string" },
        "ManufacturerSerialNumber": { "type": "string" },
        "InventoryNumber": { "type": "string" },
        "GrossWeight": { "type": "integer" },
        "GrossWeightUnit": { "type": "string" },
        "SizeOrDimensionText": { "type": "string" },
        "MaintObjectLocAcctAssgmtNmbr": { "type": "string" },
        "MaintenancePlanningPlant": { "type": "string" },
        "MaintenancePlannerGroup": { "type": "string" },
        "CompanyCode": { "type": "string" },
        "IsDeleted": { "type": "boolean" },
        "TechObjStatusIsInactive": { "type": "boolean" },
        "PurchaseOrder": { "type": "string" },
        "Supplier": { "type": "string" },
        "RealEstateContract": { "type": "string" },
        "WBSElementInternalID": { "type": "string" },
        "MasterFixedAsset": { "type": "string" },
        "_CompanyCode": { "type": "string", "x-nullable": true },
        "_EquipmentText": {
          "type": "array",
          "items": { "$ref": "#/definitions/EquipmentText" }
        },
        "_MasterFixedAsset": { "type": "string", "x-nullable": true },
        "_Supplier": { "type": "string", "x-nullable": true },
        "_TechnicalObjectTypeText": {
          "type": "array",
          "items": { "type": "string" }
        },
        "_WBSElement": { "type": "string", "x-nullable": true }
      },
      "required": [
        "Equipment",
        "MaintObjectInternalID",
        "TechnicalObjectType",
        "AssetManufacturerName",
        "ManufacturerPartTypeName",
        "ManufacturerPartNmbr",
        "ManufacturerSerialNumber",
        "InventoryNumber",
        "GrossWeight",
        "GrossWeightUnit",
        "SizeOrDimensionText",
        "MaintObjectLocAcctAssgmtNmbr",
        "MaintenancePlanningPlant",
        "MaintenancePlannerGroup",
        "CompanyCode",
        "IsDeleted",
        "TechObjStatusIsInactive",
        "PurchaseOrder",
        "Supplier",
        "RealEstateContract",
        "WBSElementInternalID",
        "MasterFixedAsset",
        "_EquipmentText",
        "_TechnicalObjectTypeText"
      ]
    },
    "EquipmentText": {
      "type": "object",
      "properties": {
        "Equipment": { "type": "string" },
        "Language": { "type": "string" },
        "EquipmentName": { "type": "string" }
      },
      "required": ["Equipment", "Language", "EquipmentName"]
    }
  }
}
